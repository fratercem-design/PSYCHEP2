# Admin Credentials (replace with secure values)
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_secure_password
# Optional: Fallback email for credentials login (must be in ADMIN_EMAILS or explicitly allowed)
ADMIN_FALLBACK_EMAIL=

# Admin Email Allowlist (comma-separated)
ADMIN_EMAILS=

# NextAuth Configuration
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=your_nextauth_secret

# Google OAuth (optional)
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# Database
DATABASE_URL=your_database_url

# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key

# Twitch API (https://dev.twitch.tv/console)
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# Kick API (no auth needed — uses public API)

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Mailchimp
MAILCHIMP_API_KEY=your_mailchimp_api_key

# Analytics (Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
